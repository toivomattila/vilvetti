# Vite + Convex (local development)
# Copy to .env.local and fill in values from `npx convex dev`.

VITE_CONVEX_URL=

# Convex Auth: set JWT_PRIVATE_KEY and JWKS on the Convex deployment
# (Dashboard → Deployment → Settings → Environment Variables), not in this file.
# Generate values: node scripts/generate-convex-auth-keys.mjs

